// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "diff_view_style": "split",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "create_directory": {
          "always_allow": [
            {
              "pattern": "^scala_zed_test/",
            },
          ],
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cargo\\s+build(\\s|$)",
            },
            {
              "pattern": "^which\\s+scala(\\s|$)",
            },
            {
              "pattern": "^java\\b",
            },
            {
              "pattern": "^head\\b",
            },
            {
              "pattern": "^sbt\\s+compile(\\s|$)",
            },
            {
              "pattern": "^ls\\s+\\~/repos/scratch_dbs(\\s|$)",
            },
            {
              "pattern": "^echo\\s+directory(\\s|$)",
            },
          ],
        },
      },
    },
    "dock": "right",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
    "model_parameters": [],
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "cursor_shape": "block",
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "buffer_font_features": {
    "calt": false,
    "liga": false,
  },
}
